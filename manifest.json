{
  "manifest_version": 3,
  "name": "Focus Blocker",
  "version": "1.0.0",
  "description": "Block distracting sites or allow only a whitelist to stay focused.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" },
  "incognito": "spanning"
}
